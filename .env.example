# Daily Wins - Environment Variables
# Copy this file to .env.local and fill in your values

# Convex Deployment URL (get this from your Convex dashboard)
VITE_CONVEX_URL=https://your-project-name.convex.cloud

# Google OAuth (for Google Sign-In)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID (Web application)
# 2. Add authorized redirect URI: https://your-project.convex.site/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Apple Sign-In (for Apple Sign-In)
# Create credentials at: https://developer.apple.com/account/resources/identifiers/add/SignIn
APPLE_CLIENT_ID=com.yourapp.dailywins

# Resend API Key (for Magic Link emails)
# Get an API key at: https://resend.com
RESEND_API_KEY=re_your_api_key

# Convex Admin Key (for backend deployments)
CONVEX_ADMIN_KEY=your-convex-admin-key
